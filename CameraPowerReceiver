using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class CameraPowerReceiver : MonoBehaviour
{
    public GameObject visualCone;
    public Collider detectionTrigger;

    public void SetPower(bool state)
    {
        visualCone.SetActive(state);
        detectionTrigger.enabled = state;

        GetComponent<CameraStateMachine>().enabled = state;
    }
}
