using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class CameraAlarm : MonoBehaviour
{
    public static CameraAlarm Instance;

    public Transform checkpoint;

    void Awake()
    {
        Instance = this;
    }

    public void TriggerAlarm()
    {
        Debug.Log("Camera detected player!");

        ResetPlayer();
    }

    void ResetPlayer()
    {
        GameObject detective = GameObject.FindGameObjectWithTag("Detective");
        detective.transform.position = checkpoint.position;
    }
}
